# ─── Gloford.org Production Environment ────────────────────
# Copy to .env on your production server and fill in real values.
# NEVER commit the filled .env file to version control.

# ─── Identity ──────────────────────────────────────────────
BRAND_NAME="Gloford"
BRAND_LOGO_URL=""
BRAND_PRIMARY_COLOR="#1a5632"
BRAND_SUPPORT_EMAIL="info@gloford.org"
BRAND_COUNTRY="UG"
BRAND_DEFAULT_CURRENCY="UGX"
BRAND_LOCALE="en"

# ─── Domain ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://gloford.org"
AUTH_URL="https://gloford.org"

# ─── Admin seed credentials ────────────────────────────────
SEED_ADMIN_EMAIL="admin@gloford.org"
SEED_ADMIN_PASSWORD=""   # generate a strong password

# ─── Database ──────────────────────────────────────────────
DB_PASSWORD=""            # used by docker-compose for postgres
DATABASE_URL="postgresql://app:${DB_PASSWORD}@db:5432/app?sslmode=disable"
DIRECT_URL="postgresql://app:${DB_PASSWORD}@db:5432/app?sslmode=disable"

# ─── Secrets (generate fresh: openssl rand -base64 32) ─────
AUTH_SECRET=""
ENCRYPTION_KEY=""

# ─── Mail ──────────────────────────────────────────────────
# Option A: SMTP relay (recommended for production)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Gloford <no-reply@gloford.org>"

# Option B: Resend (SaaS fallback)
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# ─── Inngest ───────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Payment webhooks ─────────────────────────────────────
MTN_MOMO_CALLBACK_SECRET=""
AIRTEL_MONEY_CALLBACK_SECRET=""
PESAPAL_IPN_ID=""

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR="/app/uploads"
# Optional: R2/S3 for cloud storage
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""

# ─── Observability ─────────────────────────────────────────
SENTRY_DSN=""
SENTRY_ENV="production"
LOG_LEVEL="info"

# ─── Docker Compose ───────────────────────────────────────
COMPOSE_PROJECT_NAME="gloford"
APP_PORT="3000"
MAILPIT_UI_PORT="8025"
