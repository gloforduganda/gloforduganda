# Keep pnpm's content-addressable store outside the repo so `pnpm add`
# doesn't pollute the working tree with thousands of .pnpm-store/ files.
# ~/.pnpm-store expands to your home directory.
store-dir=~/.pnpm-store

# Enforce strict peer dependency checks so typos fail loud.
strict-peer-dependencies=true

# Avoid writing telemetry to a .pnpm-telemetry file in-project.
update-notifier=false
