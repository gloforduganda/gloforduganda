# ─── White-label identity ───────────────────────────────────
# Each deployment is a single client. These vars control branding,
# admin credentials, and support contact. Change per client.
BRAND_NAME="Acme Foundation"
BRAND_LOGO_URL="https://assets.example.org/logo.png"
BRAND_PRIMARY_COLOR="#2563eb"
BRAND_SUPPORT_EMAIL="support@example.org"
BRAND_COUNTRY="KE"
BRAND_DEFAULT_CURRENCY="USD"
BRAND_LOCALE="en"

# ─── Initial admin user (seeded on first migrate) ───────────
SEED_ADMIN_EMAIL="admin@example.org"
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# ─── Database (Neon / Postgres) ─────────────────────────────
# Each client gets their own database. Same connection string for both
# URL vars (no role split needed in single-tenant).
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Auth.js ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
# Set to your domain in production. For local Docker: http://localhost:3000
APP_URL="https://yourdomain.com"

# Optional Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Encryption (provider secrets at rest) ──────────────────
# AES-256-GCM key. Generate: openssl rand -base64 32
# Must be distinct per client deployment.
ENCRYPTION_KEY=""

# ─── Mail (self-hosted SMTP — recommended) ─────────────────
# Set SMTP_HOST to use your own mail server. Mailpit is included
# in docker-compose for dev. For production, point to your MTA.
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Acme Foundation <no-reply@example.org>"

# ─── Mail (Resend — SaaS fallback) ─────────────────────────
# Only used when SMTP_HOST is not set.
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# ─── Inngest ────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Payment provider webhook signing secrets ──────────────
# Paste the per-provider dashboard secret into its env var. The
# provider's API keys are entered via the admin UI and encrypted
# at rest with ENCRYPTION_KEY.
MTN_MOMO_CALLBACK_SECRET=""
AIRTEL_MONEY_CALLBACK_SECRET=""
PESAPAL_IPN_ID=""

# ─── Storage (local filesystem — self-hosted) ──────────────
# Images are stored on the server at UPLOAD_DIR and served via
# /api/media/file/[key]. No cloud storage needed.
UPLOAD_DIR="/app/uploads"

# ─── Observability ──────────────────────────────────────────
# Optional — loaded dynamically from instrumentation.ts when set.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_ENV="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"
LOG_LEVEL="info"

# ─── Search (Meilisearch) ────────────────────────────────────
# Optional — when set, content is indexed and /search is enabled.
# Run locally: docker run -p 7700:7700 getmeili/meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""
