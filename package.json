{
  "name": "ngo-platform",
  "version": "0.1.0",
  "description": "White-label NGO platform — single-tenant, env-configured. Fork once per client.",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
 pnpm@10.0.0 --activate
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "inngest:dev": "npx inngest-cli@latest dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "audit:ui": "grep -rn \"window\\.confirm\\|window\\.alert\\|window\\.prompt\" app/ components/ || true"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.12",
      "fast-xml-parser": "^5.7.0",
      "handlebars": "^4.7.9",
      "vite": "^6.4.2"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
